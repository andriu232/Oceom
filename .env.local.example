# ============================================================
# OCEOM by E-MOTION® — Variables de entorno
# Copia este archivo a .env.local y rellena con tus valores reales.
# ============================================================

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Solo server-side. NUNCA exponer al cliente. (Service role / secret key)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# IA — AURA (Sprint 8+). Provider-agnostic; se activa cuando haya crédito.
# AURA_PROVIDER=anthropic   # anthropic | openai | mock
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Email (Sprint 11+)
# RESEND_API_KEY=

# Windows: si el TLS corporativo rompe fetch en dev, descomenta en tu shell:
# NODE_OPTIONS=--use-system-ca
